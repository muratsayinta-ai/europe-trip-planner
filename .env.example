# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real keys.

# Google Maps key (Places API New + Maps JavaScript API). Restrict it in Google
# Cloud Console to your deployed domain (HTTP referrers).
VITE_GMAPS_KEY=

# Google Gemini key (optional — AI place suggestions). aistudio.google.com/apikey
VITE_GEMINI_KEY=

# Supabase shared-trip sync (Project Settings → API). Leave blank for local-only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
